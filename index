function openPasteModal(initialFile) {
  makeModal('📷 Paste Screenshot to Create Order', `
    <div id="dropZone" class="drop-zone">
      <div style="font-size:32px;">📋</div>
      <div style="color:var(--text-muted); margin-top:8px;">
        <strong>Paste (Ctrl/Cmd+V)</strong>, drop, or
        <label style="color:var(--primary); cursor:pointer; text-decoration:underline;">choose file<input type="file" id="filePicker" accept="image/*" hidden/></label>
      </div>
      <div class="hint" style="margin-top:8px;">Vendor confirmations, packing slips, shipping notifications</div>
      <img id="preview" class="preview" style="display:none;"/>
      <div id="processing" style="display:none; margin-top:12px;"><span class="spinner"></span> <span style="color:var(--indigo); font-weight:500;">Reading with Claude…</span></div>
    </div>
  `, [{ label: 'Cancel', onClick: closeModal }]);

  const dz = document.getElementById('dropZone');
  const preview = document.getElementById('preview');
  const proc = document.getElementById('processing');
  const fp = document.getElementById('filePicker');

  fp.addEventListener('change', e => { if (e.target.files[0]) handle(e.target.files[0]); });
  dz.addEventListener('click', e => { if (e.target.tagName !== 'LABEL' && e.target.tagName !== 'INPUT') fp.click(); });
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
  dz.addEventListener('drop', e => { e.preventDefault(); dz.classList.remove('dragover'); const f = [...e.dataTransfer.files].find(f => f.type.startsWith('image/')); if (f) handle(f); });

  function pasteHandler(e) {
    const item = [...e.clipboardData.items].find(i => i.type.startsWith('image/'));
    if (item) { e.preventDefault(); handle(item.getAsFile()); }
  }
  document.addEventListener('paste', pasteHandler);

  async function handle(file) {
    const reader = new FileReader();
    reader.onload = async () => {
      preview.src = reader.result; preview.style.display = 'block';
      proc.style.display = 'block'; dz.classList.add('processing');
      const base64 = reader.result.split(',')[1];
      try {
        const data = await api('extract', { imageBase64: base64, mediaType: file.type || 'image/png' });
        const ex = data.extracted;
        document.removeEventListener('paste', pasteHandler);
        closeModal();
        openOrderModal(null, {
          date: ex.date || new Date().toISOString().slice(0,10),
          job: ex.job || '', customer: ex.customer || '', invoice: ex.invoice || '',
          parts: ex.parts || '', source: ex.source || '',
          status: 'Ordered', paid: 'No', shipType: 'WRS Ship',
          carrier: CARRIERS.includes(ex.carrier) ? ex.carrier : '',
          tracking: ex.tracking || '', dropFrom: '', freightNeed: '', freightBilledBy: '',
          freightCost: ex.freightCost ? Number(ex.freightCost) : '',
          fromZip: ex.fromZip || '', toZip: ex.toZip || '',
          weight: ex.weight ? Number(ex.weight) : '', notes: ex.notes || ''
        });
        toast('Extracted — review and save', 'success');
      } catch (err) {
        proc.style.display = 'none'; dz.classList.remove('processing');
        toast('Extraction failed: ' + err.message, 'error');
      }
    };
    reader.readAsDataURL(file);
  }
  if (initialFile) handle(initialFile);
}

function openEmailModal(order) {
  const carrierLink = CARRIER_URLS[order.carrier] && order.tracking ? CARRIER_URLS[order.carrier](order.tracking) : '';
  const subject = order.tracking
    ? `Parts Shipped — ${order.job || order.invoice}`
    : `Update on order ${order.invoice || order.job}`;
  const body = order.tracking
    ? `Hello,\n\nYour parts for job ${order.job} have shipped.\n\nInvoice: ${order.invoice}\nParts: ${order.parts}\nCarrier: ${order.carrier}\nTracking #: ${order.tracking}\n${carrierLink ? 'Track: ' + carrierLink : ''}\n\n— ${shop.name}`
    : `Hello,\n\nUpdate on your parts order ${order.invoice}:\n\nParts: ${order.parts}\nStatus: ${order.status}\n\n— ${shop.name}`;

  makeModal('✉️ Send Email', `
    <div class="field"><label>To</label><input id="em_to" placeholder="recipient@example.com"/></div>
    <div class="field" style="margin-top:10px;"><label>Subject</label><input id="em_subj" value="${escapeAttr(subject)}"/></div>
    <div class="field" style="margin-top:10px;"><label>Message</label><textarea id="em_body" rows="11" style="font-family:ui-monospace,monospace; font-size:12px;">${escapeHtml(body)}</textarea></div>
  `, [
    { label: 'Cancel', onClick: closeModal },
    { label: 'Send', primary: true, onClick: async () => {
      const to = document.getElementById('em_to').value.trim();
      if (!to) { toast('Recipient required', 'error'); return; }
      try {
        await api('sendEmail', {
          id: order.id, type: order.tracking ? 'shipping' : 'update', to,
          subject: document.getElementById('em_subj').value,
          bodyText: document.getElementById('em_body').value
        });
        toast('Sent', 'success'); closeModal(); await reload();
      } catch (err) { toast(err.message, 'error'); }
    }}
  ]);
}

async function openLogModal(order) {
  makeModal(`🕒 Log — ${order.invoice || order.job || order.id}`, `<div id="logBody"><span class="spinner"></span> Loading…</div>`, [{ label: 'Close', onClick: closeModal }]);
  try {
    const data = await api('log', { id: order.id });
    document.getElementById('logBody').innerHTML = data.log.length
      ? data.log.map(e => `<div class="log-entry"><div class="log-ts">${escapeHtml(e.ts)}</div><div class="log-action">${escapeHtml(e.action)}</div><div class="log-user">${escapeHtml(e.user)}</div></div>`).join('')
      : '<div class="empty">No log entries.</div>';
  } catch (err) {
    document.getElementById('logBody').innerHTML = `<div class="empty">Failed: ${escapeHtml(err.message)}</div>`;
  }
}

function openVendorsModal() {
  const renderList = () => vendors.map((v, i) => `
    <div class="quote-row" data-vidx="${i}">
      <div><strong>${escapeHtml(v.name)}</strong><div style="font-size:11px;color:var(--text-muted);">${escapeHtml(v.address || '—')} ${escapeHtml(v.zip)}</div></div>
      <div style="font-size:11px;">${escapeHtml(v.contact || '')}<br/><span style="color:var(--text-muted);">${escapeHtml(v.phone || '')}</span></div>
      <div style="font-size:11px;">${escapeHtml(v.email || '')}</div>
      <div><button class="btn" data-vedit="${i}">Edit</button></div>
    </div>`).join('');

  makeModal('📇 Vendors / Sources', `
    <div style="display:flex; gap:8px; margin-bottom:12px;">
      <button class="btn btn-primary" id="v_new">+ New Vendor</button>
      <span class="hint" style="margin-left:auto;">${vendors.length} vendors</span>
    </div>
    <div id="v_list">${renderList()}</div>
  `, [{ label: 'Close', onClick: closeModal }]);

  document.getElementById('v_new').addEventListener('click', () => editVendor({}));
  document.querySelectorAll('[data-vedit]').forEach(b => b.addEventListener('click', () => editVendor(vendors[Number(b.dataset.vedit)])));
}

function editVendor(v) {
  const isNew = !v.name;
  makeModal(isNew ? '+ New Vendor' : 'Edit ' + v.name, `
    <div class="form-grid">
      <div class="field span2"><label>Name *</label><input id="v_name" value="${escapeAttr(v.name||'')}" ${isNew?'':'readonly'}/></div>
      <div class="field"><label>ZIP</label><input id="v_zip" value="${escapeAttr(v.zip||'')}"/></div>
      <div class="field full"><label>Address</label><input id="v_addr" value="${escapeAttr(v.address||'')}"/></div>
      <div class="field"><label>Contact</label><input id="v_contact" value="${escapeAttr(v.contact||'')}"/></div>
      <div class="field"><label>Phone</label><input id="v_phone" value="${escapeAttr(v.phone||'')}"/></div>
      <div class="field"><label>Email</label><input id="v_email" value="${escapeAttr(v.email||'')}"/></div>
    </div>
  `, [
    { label: 'Cancel', onClick: closeModal },
    { label: 'Save', primary: true, onClick: async () => {
      const data = {
        name: document.getElementById('v_name').value.trim(),
        zip: document.getElementById('v_zip').value.trim(),
        address: document.getElementById('v_addr').value.trim(),
        contact: document.getElementById('v_contact').value.trim(),
        phone: document.getElementById('v_phone').value.trim(),
        email: document.getElementById('v_email').value.trim()
      };
      if (!data.name) { toast('Name required','error'); return; }
      try { await api('saveVendor', { vendor: data }); toast('Saved','success'); closeModal(); await reload(); openVendorsModal(); }
      catch (err) { toast(err.message,'error'); }
    }}
  ]);
}

async function doDelete(order) {
  if (!confirm(`Delete order ${order.invoice || order.job}?\n\nThis cannot be undone.`)) return;
  try { await api('delete', { id: order.id }); toast('Deleted', 'success'); await reload(); }
  catch (err) { toast(err.message, 'error'); }
}

function makeModal(title, bodyHtml, buttons) {
  closeModal();
  const wrap = document.createElement('div');
  wrap.className = 'modal-bg';
  wrap.innerHTML = `<div class="modal"><div class="modal-header"><h2>${title}</h2><button class="icon-btn" id="modalClose">✕</button></div><div class="modal-body">${bodyHtml}</div><div class="modal-footer" id="modalFooter"></div></div>`;
  document.body.appendChild(wrap);
  const footer = wrap.querySelector('#modalFooter');
  buttons.forEach(b => {
    const btn = document.createElement('button');
    btn.className = 'btn' + (b.primary ? ' btn-primary' : '');
    btn.textContent = b.label;
    btn.addEventListener('click', b.onClick);
    footer.appendChild(btn);
  });
  wrap.querySelector('#modalClose').addEventListener('click', closeModal);
  wrap.addEventListener('click', e => { if (e.target === wrap) closeModal(); });
  return wrap;
}
function closeModal() {
  document.querySelectorAll('.modal-bg').forEach(m => m.remove());
}
function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function escapeAttr(s) { return escapeHtml(s); }
</script>
</body>
</html>
