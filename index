function setupCustomerAutocomplete(order) {
  const input = document.getElementById('f_customer');
  const list = document.getElementById('f_customer_ac');
  const sitePicker = document.getElementById('f_site_picker');
  let debounceTimer = null, activeIdx = -1, currentResults = [];

  if (order && order.customerId) loadSitesAndShow(order.customerId);

  input.addEventListener('input', () => {
    input.dataset.customerId = '';
    sitePicker.style.display = 'none';
    sitePicker.innerHTML = '';
    const q = input.value.trim();
    if (q.length < 2) { hideList(); return; }
    list.style.display = 'block';
    list.innerHTML = '<div class="ac-loading"><span class="spinner"></span> Searching…</div>';
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      try {
        const data = await api('searchCustomers', { query: q, limit: 10 });
        currentResults = data.results || [];
        activeIdx = -1;
        renderList();
      } catch (err) {
        list.innerHTML = `<div class="ac-empty">Error: ${escapeHtml(err.message)}</div>`;
      }
    }, 200);
  });

  input.addEventListener('keydown', (e) => {
    if (list.style.display === 'none' || !currentResults.length) return;
    if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(activeIdx + 1, currentResults.length - 1); renderList(); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = Math.max(activeIdx - 1, 0); renderList(); }
    else if (e.key === 'Enter' && activeIdx >= 0) { e.preventDefault(); selectCustomer(currentResults[activeIdx]); }
    else if (e.key === 'Escape') hideList();
  });

  document.addEventListener('click', (e) => {
    if (!input.contains(e.target) && !list.contains(e.target)) hideList();
  });

  function renderList() {
    if (!currentResults.length) {
      list.innerHTML = `<div class="ac-empty">No matches. Press Save to add as new customer.</div>`;
      return;
    }
    list.innerHTML = currentResults.map((c, i) => {
      const sub = c.defaultSite
        ? `${c.defaultSite.address || ''}${c.defaultSite.city ? ', ' + c.defaultSite.city : ''}${c.defaultSite.state ? ', ' + c.defaultSite.state : ''} ${c.defaultSite.zip || ''}`
        : (c.phone || '');
      const multiBadge = c.siteCount > 1 ? `<span class="ac-multi">${c.siteCount} sites</span>` : '';
      return `<div class="ac-item ${i === activeIdx ? 'active' : ''}" data-idx="${i}">
        <div class="ac-name">${escapeHtml(c.name)}${multiBadge}</div>
        <div class="ac-sub">${escapeHtml(sub.trim() || '—')}</div>
      </div>`;
    }).join('');
    list.querySelectorAll('.ac-item').forEach(el => {
      el.addEventListener('mousedown', (e) => {
        e.preventDefault();
        selectCustomer(currentResults[Number(el.dataset.idx)]);
      });
    });
  }

  function hideList() { list.style.display = 'none'; activeIdx = -1; }

  async function selectCustomer(customer) {
    input.value = customer.name;
    input.dataset.customerId = customer.id;
    hideList();
    await loadSitesAndShow(customer.id);
  }

  async function loadSitesAndShow(customerId) {
    try {
      const data = await api('getSites', { customerId });
      const sites = data.sites || [];
      if (sites.length === 0) { sitePicker.style.display = 'none'; return; }
      if (sites.length === 1) {
        applySite(sites[0]);
        sitePicker.style.display = 'block';
        sitePicker.innerHTML = `<div style="font-size:11px; color:var(--text-muted);">Ship to: <strong>${escapeHtml(formatSite(sites[0]))}</strong></div>`;
      } else {
        const def = sites.findIndex(s => s.default);
        const selected = def >= 0 ? def : 0;
        applySite(sites[selected]);
        sitePicker.style.display = 'block';
        sitePicker.innerHTML = `
          <label style="font-size:10px; text-transform:uppercase; color:var(--text-muted); font-weight:600;">Ship to which site?</label>
          <select id="f_site_select" style="width:100%; padding:7px 10px; font-size:13px; border:1px solid var(--border-strong); border-radius:6px; margin-top:3px;">
            ${sites.map((s, i) => `<option value="${i}" ${i === selected ? 'selected' : ''}>${escapeHtml(formatSite(s))}${s.default ? ' (default)' : ''}</option>`).join('')}
          </select>`;
        document.getElementById('f_site_select').addEventListener('change', (e) => applySite(sites[Number(e.target.value)]));
      }
    } catch (err) {
      sitePicker.style.display = 'block';
      sitePicker.innerHTML = `<div style="font-size:11px; color:var(--warn);">Site load failed</div>`;
    }
  }

  function applySite(site) { if (site.zip) document.getElementById('f_toZip').value = site.zip; }
  function formatSite(s) { return [s.siteName, [s.address, s.city, s.state].filter(Boolean).join(', '), s.zip].filter(Boolean).join(' · '); }
}

